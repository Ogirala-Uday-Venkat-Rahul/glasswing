# Copy to .env and fill in. Names only here — never commit real values.

# --- LLM (reuse existing Groq key) ---
GROQ_API_KEY=

# --- Tools ---
SERPER_API_KEY=        # Google search results (serper.dev, free tier)
FIRECRAWL_API_KEY=     # fallback fetcher for JS-heavy / bot-protected pages

# --- Database (Neon Postgres — P3 gets its own project) ---
DATABASE_URL=

# --- Image storage (Cloudflare R2, S3-compatible) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=          # https://<account_id>.r2.cloudflarestorage.com

# --- Google OAuth (hand-rolled) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URI=   # e.g. http://localhost:8000/auth/callback in dev
SESSION_SECRET=       # signs the session cookie

# --- Observability (optional; trace.py is a no-op unless these are set) ---
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com

# --- Frontend ---
# Set in the frontend build env, not here:
# VITE_API_BASE_URL=http://localhost:8000
