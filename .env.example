# Copy to .env and fill in. Names only here — never commit real values.

# --- LLM (reuse existing Groq key) ---
GROQ_API_KEY=

# --- Tools ---
SERPER_API_KEY=        # Google search results (serper.dev, free tier)
FIRECRAWL_API_KEY=     # fallback fetcher for JS-heavy / bot-protected pages

# --- Database (Neon Postgres — P3 gets its own project) ---
DATABASE_URL=

# --- Image storage (any S3-compatible provider: Supabase Storage, R2, Backblaze) ---
# Supabase: Project Settings -> Storage -> S3 Connection for the endpoint + region,
# then generate an S3 access key. R2: endpoint is https://<account-id>.r2.cloudflarestorage.com
# and region "auto".
S3_ENDPOINT=           # e.g. https://<project-ref>.storage.supabase.co/storage/v1/s3
S3_REGION=             # e.g. us-east-1 (Supabase); "auto" for R2
S3_ACCESS_KEY_ID=      # S3 access key id
S3_SECRET_ACCESS_KEY=  # S3 secret access key
S3_BUCKET=             # the bucket name you create (e.g. uploads)

# --- Google OAuth (hand-rolled) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URI=   # e.g. http://localhost:8000/auth/callback in dev
SESSION_SECRET=       # signs the session cookie

# --- Observability (optional; trace.py is a no-op unless these are set) ---
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com

# --- Frontend ---
# Set in the frontend build env, not here:
# VITE_API_BASE_URL=http://localhost:8000
